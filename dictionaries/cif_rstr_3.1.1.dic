    _description_example.case
;
        loop_
          _restr_plane.id
          _restr_plane.atom_site_label
          _restr_plane.site_symmetry
          _restr_plane.class_id
          _restr_plane.target_weight_param
          _restr_plane.displacement
          _restr_plane.details
            1 C1 1_555 1 0.02   0.002(1) 'C1 to C4 lie on one plane'
            2 C2 1_555 1 0.02  -0.003(2) ?
            3 C3 1_555 1 0.02  -0.002(1) ?
            4 C4 1_555 1 0.02   0.002(2) ?
            5 C1 2_655 2 0.003  0.004(1) 'C1, C5, C6 and C7 lie on one plane'
            6 C5 1_555 2 0.003 -0.002(2) ?
            7 C6 1_555 2 0.003  0.002(3) ?
            8 C7 1_555 2 0.003 -0.002(2) ?
;
    _description_example.detail
;
       Example 1. This lists the atoms that define each plane, each plane
       being composed of atoms from the same class.
;

